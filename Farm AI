    <script>
        const initCharts = () => {
            const chartOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: 'system-ui', size: 12 },
                            color: '#57534e'
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(28, 25, 23, 0.9)',
                        padding: 12,
                        titleFont: { size: 14, family: 'system-ui' },
                        bodyFont: { size: 13, family: 'system-ui' },
                        cornerRadius: 8,
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) { label += ': '; }
                                if (context.parsed.y !== null && context.chart.canvas.id === 'errorChart') {
                                    label += context.parsed.y + ' помилок / 1000';
                                } else if (context.parsed !== null && context.chart.canvas.id === 'timeChart') {
                                    label += context.parsed + '% часу';
                                }
                                return label;
                            }
                        }
                    }
                }
            };

            const ctxError = document.getElementById('errorChart').getContext('2d');
            const errorChart = new Chart(ctxError, {
                type: 'bar',
                data: {
                    labels: ['Класичний підхід', 'Фармацевт + ШІ'],
                    datasets: [{
                        label: 'Кількість критичних помилок',
                        data: [100, 15],
                        backgroundColor: [
                            'rgba(244, 63, 94, 0.8)',
                            'rgba(13, 148, 136, 0.8)'
                        ],
                        borderColor: [
                            'rgb(225, 29, 72)',
                            'rgb(15, 118, 110)'
                        ],
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    ...chartOptions,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f5f5f4' },
                            ticks: { color: '#78716c' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#44403c', font: { weight: 'bold' } }
                        }
                    }
                }
            });

            const ctxTime = document.getElementById('timeChart').getContext('2d');
            const timeChart = new Chart(ctxTime, {
                type: 'doughnut',
                data: {
                    labels: ['Рутинні перевірки/документація', 'Консультування пацієнта'],
                    datasets: [{
                        data: [60, 40],
                        backgroundColor: [
                            'rgba(168, 162, 158, 0.8)',
                            'rgba(13, 148, 136, 0.8)'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2,
                        hoverOffset: 4
                    }]
                },
                options: {
                    ...chartOptions,
                    cutout: '65%',
                    plugins: {
                        ...chartOptions.plugins,
                        tooltip: {
                            ...chartOptions.plugins.tooltip,
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': ' + context.parsed + '%';
                                }
                            }
                        }
                    }
                }
            });

            setTimeout(() => {
                if (timeChart && timeChart.data && timeChart.data.datasets[0]) {
                    timeChart.data.datasets[0].data = [20, 80];
                    timeChart.data.labels = ['Рутина (після ШІ)', 'Консультування (+2 години)'];
                    timeChart.update();
                }
            }, 3000);
        };

        const initTabs = () => {
            const btns = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.tab-content');

            btns.forEach(btn => {
                btn.addEventListener('click', () => {
                    btns.forEach(b => {
                        b.classList.remove('bg-teal-700', 'text-white', 'shadow-md');
                        b.classList.add('bg-white', 'text-stone-600');
                    });
                    
                    btn.classList.remove('bg-white', 'text-stone-600');
                    btn.classList.add('bg-teal-700', 'text-white', 'shadow-md');

                    contents.forEach(c => c.classList.remove('active'));
                    
                    const targetId = btn.getAttribute('data-target');
                    document.getElementById(targetId).classList.add('active');
                });
            });
        };

        document.addEventListener('DOMContentLoaded', () => {
            initCharts();
            initTabs();
            
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    document.querySelector(this.getAttribute('href')).scrollIntoView({
                        behavior: 'smooth'
                    });
                });
            });
        });
    </script>
</body>
</html>
